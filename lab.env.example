# lab.env — SOURCE UNIQUE de la topologie du lab.
# Lu par le Vagrantfile ET talos/cluster-up.sh (fini le « garder aligné à la main »).
#
# Copie ce modèle puis édite ta topologie en local (lab.env est gitignoré) :
#     cp lab.env.example lab.env
#
# Format strict : une seule affectation KEY=value par ligne, sans espaces ni `;`.
# Une variable d'environnement réelle reste prioritaire (ex. `WORKERS=6 vagrant up`).

# Version Talos : pilote l'ISO (Vagrant) ET l'image d'installeur épinglée par
# cluster-up.sh (--install-image). À garder alignée sur la version de `talosctl`.
TALOS_VERSION=v1.13.7

# CHOIX DE L'IMAGE D'INSTALLEUR (extensions système bakées ou non) :
#   L'ISO de boot reste la classic ; les extensions sont tirées de l'INSTALLEUR (--install-image).
#
# DÉFAUT DU LAB = image « Longhorn » (Image Factory) : inclut iscsi-tools + util-linux-tools,
# requis par Longhorn (cf. _k8s/longhorn/schematic.yaml). Schematic déterministe (mêmes
# extensions => même ID). Régénérer si besoin : voir _k8s/longhorn/README.md.
INSTALLER_IMAGE=factory.talos.dev/installer/613e1592b2da41ae5e265e8789429f22e121aab91cb4deb6bc3c0b6262961245:v1.13.7
#
# ALTERNATIVE « Ceph » (Rook-Ceph) : AUCUNE extension nécessaire — RBD est dans le noyau
# Talos (source : docs.siderolabs.com/kubernetes-guides/csi/ceph-with-rook). Utiliser
# l'installeur CLASSIC (commenter la ligne ci-dessus ou la vider) :
#   INSTALLER_IMAGE=          # => ghcr.io/siderolabs/installer:${TALOS_VERSION} (classic)
# Prérequis Ceph côté Talos : disques bruts dédiés (sans partition) + PodSecurity
# `privileged` sur le ns rook-ceph. (Longhorn = iscsi-tools ; Ceph = rien de spécial.)

# Topologie : 1 CP = single ; 3 CP = HA (avec VIP)
CONTROL_PLANES=3
WORKERS=3

# Ressources par rôle (lues par le Vagrantfile). Un CP est plus gourmand
# (etcd + apiserver) : 3072/3 recommandé dès qu'on empile des add-ons.
CP_MEM=2048
CP_CPU=2
WK_MEM=2048
WK_CPU=2

# CNI installé par Talos au bootstrap (lu par cluster-up.sh) :
#   flannel = défaut (fix VXLAN host-only) ; none = tu poses Cilium & co toi-même.
CNI=flannel

# Token API Cloudflare pour le DNS-01 de cert-manager (permissions Zone:DNS:Edit +
# Zone:Zone:Read sur la zone). Laisse vide ici : la vraie valeur va dans lab.env
# (gitignoré), jamais dans ce modèle versionné.
CLOUDFLARE_API_TOKEN=

# Réseau host-only
NETWORK=192.168.56

# Schéma d'adressage : CP -> .10/.20/.30 ; workers -> .101/.102/...
CP_IP_START=10
CP_IP_STEP=10
WK_IP_START=101
WK_IP_STEP=1
