# lab.env — SOURCE UNIQUE de la topologie du lab.
# Lu par le Vagrantfile ET talos/cluster-up.sh (fini le « garder aligné à la main »).
#
# Copie ce modèle puis édite ta topologie en local (lab.env est gitignoré) :
#     cp lab.env.example lab.env
#
# Format strict : une seule affectation KEY=value par ligne, sans espaces ni `;`.
# Une variable d'environnement réelle reste prioritaire (ex. `WORKERS=6 vagrant up`).

# Version Talos (ISO téléchargée par Vagrant)
TALOS_VERSION=v1.13.5

# Topologie : 1 CP = single ; 3 CP = HA (avec VIP)
CONTROL_PLANES=3
WORKERS=3

# Réseau host-only
NETWORK=192.168.56

# Schéma d'adressage : CP -> .10/.20/.30 ; workers -> .101/.102/...
CP_IP_START=10
CP_IP_STEP=10
WK_IP_START=101
WK_IP_STEP=1
